# ═══════════════════════════════════════════════════════════════
# AgentRouteAI — Environment Configuration
# Copy this to .env and fill in your actual keys
# ═══════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
FLASK_DEBUG=true

# ── MySQL Database ─────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=shipment_risk_db

# ── LLM Configuration (Groq — free tier) ──────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Weather (OpenWeatherMap — free, 1000 calls/day) ────────────
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ── News Search (Tavily — free tier) ──────────────────────────
# https://tavily.com
TAVILY_API_KEY=your_tavily_key_here

# ── Vessel Tracking (AISStream — free) ────────────────────────
# https://aisstream.io
AISSTREAM_API_KEY=your_aisstream_key_here

# ── Google Maps (optional, for future use) ────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── Agent Tuning ──────────────────────────────────────────────
AGENT_MAX_RETRIES=2
WEATHER_CACHE_TTL=3600
NEWS_CACHE_TTL=21600
